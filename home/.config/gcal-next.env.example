# gcal-next.env — configures which calendars the polybar gcal module watches.
# Copy to ~/.config/gcal-next.env and edit with your real calendar names/emails.
# Each calendar needs its own --cal entry. Without this file, gcalcli will query
# all accessible calendars.

GCAL_CAL_ARGS=(
    # --cal "YOUR_EMAIL_ADDRESS"
    # --cal "Work Calendar Name"
)

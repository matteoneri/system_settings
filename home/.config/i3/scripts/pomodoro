#!/bin/bash
# Pomodoro timer: 25 min focus / 5 min break
# Toggle on/off by running again

PIDFILE="/tmp/pomodoro-daemon.pid"

# If daemon is running, stop it
if [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    kill -- -"$(cat "$PIDFILE")" 2>/dev/null
    rm -f "$PIDFILE"
    notify-send -t 2000 "Pomodoro" "Stopped"
    exit 0
fi

~/.config/i3/scripts/fullscreen-alert "FOCUS TIME" "25 MINUTES" &
setsid ~/.config/i3/scripts/pomodoro-daemon </dev/null >/dev/null 2>&1 &

#!/bin/bash
# Day/Night theme switcher
# Day (9am-6pm): Amber    Night (6pm-9am): Light Blue
# Usage: theme-switch [day|night]  — argument forces mode, otherwise uses clock

if [[ "$1" == "day" || "$1" == "night" ]]; then
    MODE="$1"
else
    HOUR=$(date +%H)
    if (( HOUR >= 9 && HOUR < 18 )); then
        MODE="day"
    else
        MODE="night"
    fi
fi

STATE_FILE="/tmp/theme-current"
[[ -z "$1" ]] && [[ -f "$STATE_FILE" ]] && [[ "$(cat "$STATE_FILE")" == "$MODE" ]] && exit 0

# Day/Night palettes
if [[ "$MODE" == "day" ]]; then
    PRIMARY="#FFB347"
    ALERT="#FFE8C0"
    DISABLED="#a67520"
    CURSOR="Bibata-Modern-Amber"
    WALLPAPER="$HOME/Pictures/wallpapers/wall_day.png"
else
    PRIMARY="#61afef"
    ALERT="#b4d7ff"
    DISABLED="#3b6ea5"
    CURSOR="Bibata-Modern-Ice"
    WALLPAPER="$HOME/Pictures/wallpapers/wall_night.jpg"
fi

# 1. Write color state file for other scripts
echo "$PRIMARY" > ~/.config/theme/current

# 2. Write polybar colors
cat > ~/.config/polybar/colors.ini <<EOF
foreground = ${PRIMARY}
primary = ${PRIMARY}
alert = ${ALERT}
disabled = ${DISABLED}
EOF

# 3. Write rofi theme override
cat > ~/.config/rofi/theme-colors.rasi <<EOF
* {
    primary: ${PRIMARY};
}
EOF

# 4. Set wallpaper
feh --bg-fill "$WALLPAPER"

# 5. Write i3 theme-colors include (border colors)
cat > ~/.config/i3/theme-colors <<EOF
client.focused          ${PRIMARY} ${PRIMARY} #282c34 ${PRIMARY} ${PRIMARY}
client.focused_inactive ${DISABLED} ${DISABLED} #282c34 ${DISABLED} ${DISABLED}
EOF

# 6. Set cursor theme
sed -i "s/^Xcursor\.theme:.*/Xcursor.theme: $CURSOR/" ~/.Xresources
xrdb -merge ~/.Xresources
mkdir -p ~/.icons/default
cat > ~/.icons/default/index.theme <<EOF
[Icon Theme]
Inherits=$CURSOR
EOF
xsetroot -cursor_name left_ptr

# 7. Reload i3 (picks up theme-colors include + exec_always restarts polybar)
echo "$MODE" > "$STATE_FILE"
i3-msg reload >/dev/null 2>&1

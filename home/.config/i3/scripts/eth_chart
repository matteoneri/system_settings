#!/bin/bash

# Fetch 24h ETH/USD price history and display as ASCII sparkline in rofi

CACHE=/tmp/eth_chart_cache.json
MAX_AGE=300  # 5 minutes

# Use cache if fresh enough
if [ -f "$CACHE" ] && [ $(($(date +%s) - $(stat -c %Y "$CACHE"))) -lt $MAX_AGE ]; then
    data=$(cat "$CACHE")
else
    data=$(curl -sf --max-time 10 \
      'https://api.coingecko.com/api/v3/coins/ethereum/market_chart?vs_currency=usd&days=1')
    if [ $? -ne 0 ] || [ -z "$data" ]; then
        # Fall back to stale cache if available
        if [ -f "$CACHE" ]; then
            data=$(cat "$CACHE")
        else
            rofi -e "Failed to fetch ETH price data" -theme ~/.config/rofi/eth-chart.rasi
            exit 0
        fi
    else
        echo "$data" > "$CACHE"
    fi
fi

# Extract prices, downsample, build multi-row chart
chart=$(echo "$data" | python3 -c '
import json, sys

data = json.load(sys.stdin)
prices = [p[1] for p in data["prices"]]

COLS = 40
ROWS = 16

n = len(prices)
step = max(1, n // COLS)
sampled = [prices[i] for i in range(0, n, step)][:COLS]

lo, hi = min(sampled), max(sampled)
span = hi - lo if hi != lo else 1
partials = " ▁▂▃▄▅▆▇"
full = "█"

# Normalize each value to 0..ROWS*8 (sub-cell precision)
heights = [int((p - lo) / span * ROWS * 8) for p in sampled]

lines = []
for row in range(ROWS, 0, -1):
    threshold = row * 8
    line = ""
    for h in heights:
        if h >= threshold:
            line += full
        elif h > threshold - 8:
            line += partials[h - (threshold - 8)]
        else:
            line += " "
    lines.append(line)

fmt = lambda v: f"{v:,.0f}" if v >= 1000 else f"{v:.2f}"

print(f"ETH/USD 24h  ·  \${fmt(lo)} \u2013 \${fmt(hi)}")
print()
for l in lines:
    print(l)
print()
print("24h ago                      now")
')

rofi -e "$chart" -theme ~/.config/rofi/eth-chart.rasi

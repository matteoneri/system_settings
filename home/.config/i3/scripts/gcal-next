#!/bin/bash

CACHE_FILE="/tmp/polybar-gcal-cache"
MAX_TITLE_LEN=30
CACHE_MAX_AGE=600  # 10 minutes
WARN_MINUTES=10

# Colors
COLOR_WARN="#FF7043"
COLOR_LIVE="#f45070"

# Icons (font 2)
ICON_NORMAL="%{T2}󰃰%{T-}"
ICON_LIVE="%{T2}󰕧%{T-}"

# Force refresh if called with --force
force=0
[[ "${1:-}" == "--force" ]] && force=1

# Check if gcalcli is available
command -v gcalcli &>/dev/null || exit 0

today=$(date +%Y-%m-%d)

# Refresh cache if missing, stale, from a different day, or forced
refresh=$force
if [[ ! -f "$CACHE_FILE" ]]; then
    refresh=1
else
    cache_day=$(head -1 "$CACHE_FILE")
    if [[ "$cache_day" != "$today" ]]; then
        refresh=1
    else
        cache_age=$(( $(date +%s) - $(stat -c %Y "$CACHE_FILE") ))
        if (( cache_age > CACHE_MAX_AGE )); then
            refresh=1
        fi
    fi
fi

if (( refresh )); then
    notify-send -t 2000 "Calendar" "Refreshing..."
    tmpfile=$(mktemp)
    if gcalcli agenda "$today" "$(date -d "$today + 1 day" +%Y-%m-%d)" \
        --cal "Matteo Neri @FNA" --cal "matteo.neri920114@gmail.com" --tsv 2>"$CACHE_FILE.err" \
        > "$tmpfile"; then
        # Build cache: date stamp on first line, parsed events after
        echo "$today" > "$CACHE_FILE"
        tail -n +2 "$tmpfile" | while IFS=$'\t' read -r start_date start_time end_date end_time title; do
            [[ -z "$start_time" || -z "$title" ]] && continue
            echo "${start_time} ${end_time} ${title}"
        done >> "$CACHE_FILE"
        count=$(( $(wc -l < "$CACHE_FILE") - 1 ))
        notify-send -t 2000 "Calendar" "$count event(s) today"
    else
        notify-send -t 3000 "Calendar" "Error: $(cat "$CACHE_FILE.err")"
        rm -f "$CACHE_FILE"  # remove broken cache so next call retries
    fi
    rm -f "$tmpfile"
fi

# If cache doesn't exist (gcalcli failed), show nothing
[[ ! -f "$CACHE_FILE" ]] && exit 0

# Check if there are any events scheduled today
event_count=$(( $(wc -l < "$CACHE_FILE") - 1 ))
if (( event_count == 0 )); then
    echo "$ICON_NORMAL No events today"
    exit 0
fi

# Convert HH:MM to minutes since midnight
time_to_min() {
    local h=${1%%:*} m=${1##*:}
    echo $(( 10#$h * 60 + 10#$m ))
}

now=$(date +%H:%M)
now_min=$(time_to_min "$now")

# Read events, filter ended ones (end_time must be strictly after now)
mapfile -t events < <(
    tail -n +2 "$CACHE_FILE" | while IFS=' ' read -r start_time end_time title; do
        [[ "$end_time" > "$now" ]] && echo "${start_time} ${end_time} ${title}"
    done
)

# All events ended: show nothing
[[ ${#events[@]} -eq 0 ]] && exit 0

# First non-ended event
event="${events[0]}"
start_time="${event%% *}"
rest="${event#* }"
end_time="${rest%% *}"
title_part="${rest#* }"

start_min=$(time_to_min "$start_time")
diff=$((start_min - now_min))

# Truncate title if too long
if (( ${#title_part} > MAX_TITLE_LEN )); then
    title_part="${title_part:0:$MAX_TITLE_LEN}.."
fi

# Determine state: live, warning (10 min), or normal
if (( diff <= 0 )); then
    # Live: event has started and hasn't ended
    echo "%{F$COLOR_LIVE}$ICON_LIVE ${start_time} ${title_part}%{F-}"
elif (( diff <= WARN_MINUTES )); then
    # Starting within 10 minutes
    echo "%{F$COLOR_WARN}$ICON_NORMAL ${start_time} ${title_part}%{F-}"
else
    # Normal
    echo "$ICON_NORMAL ${start_time} ${title_part}"
fi

#!/bin/bash
# Polybar tail script for Google Calendar events
# Runs continuously: refreshes cache, displays next event with color states, blinks when live

CACHE_FILE="/tmp/polybar-gcal-cache"
FORCE_FILE="/tmp/polybar-gcal-force"
MAX_TITLE_LEN=30
CACHE_MAX_AGE=600  # 10 minutes
WARN_MINUTES=10

# Colors
BG_COLOR="#282c34"
COLOR_WARN="#FF7043"
COLOR_LIVE="#f45070"

# Icons (font 2)
ICON_NORMAL="%{T2}󰃰%{T-}"
ICON_LIVE="%{T2}󰕧%{T-}"

command -v gcalcli &>/dev/null || exit 0

time_to_min() {
    local h=${1%%:*} m=${1##*:}
    echo $(( 10#$h * 60 + 10#$m ))
}

refresh_cache() {
    local force=$1
    local today=$(date +%Y-%m-%d)
    local refresh=$force

    if [[ ! -f "$CACHE_FILE" ]]; then
        refresh=1
    else
        local cache_day=$(head -1 "$CACHE_FILE")
        if [[ "$cache_day" != "$today" ]]; then
            refresh=1
        elif (( $(date +%s) - $(stat -c %Y "$CACHE_FILE") > CACHE_MAX_AGE )); then
            refresh=1
        fi
    fi

    if (( refresh )); then
        notify-send -t 2000 "Calendar" "Refreshing..."
        local tmpfile=$(mktemp)
        if gcalcli agenda "$today" "$(date -d "$today + 1 day" +%Y-%m-%d)" \
            --cal "Matteo Neri @FNA" --cal "matteo.neri920114@gmail.com" --tsv 2>"$CACHE_FILE.err" \
            > "$tmpfile"; then
            echo "$today" > "$CACHE_FILE"
            tail -n +2 "$tmpfile" | while IFS=$'\t' read -r _ start_time _ end_time title; do
                [[ -z "$start_time" || -z "$title" ]] && continue
                echo "${start_time} ${end_time} ${title}"
            done >> "$CACHE_FILE"
            local count=$(( $(wc -l < "$CACHE_FILE") - 1 ))
            notify-send -t 2000 "Calendar" "$count event(s) today"
        else
            notify-send -t 3000 "Calendar" "Error: $(cat "$CACHE_FILE.err")"
            rm -f "$CACHE_FILE"
        fi
        rm -f "$tmpfile"
    fi
}

while true; do
    # Check for force-refresh flag (from click handler)
    force=0
    if [[ -f "$FORCE_FILE" ]]; then
        rm -f "$FORCE_FILE"
        force=1
    fi

    refresh_cache $force

    # No cache (gcalcli failed) — wait and retry
    if [[ ! -f "$CACHE_FILE" ]]; then
        echo ""
        sleep 60
        continue
    fi

    # No events scheduled today
    event_count=$(( $(wc -l < "$CACHE_FILE") - 1 ))
    if (( event_count == 0 )); then
        echo "$ICON_NORMAL No events today"
        sleep 30
        continue
    fi

    now=$(date +%H:%M)
    now_min=$(time_to_min "$now")

    # Filter to non-ended events
    mapfile -t events < <(
        tail -n +2 "$CACHE_FILE" | while IFS=' ' read -r st et title; do
            [[ "$et" > "$now" ]] && echo "${st} ${et} ${title}"
        done
    )

    # All events ended
    if [[ ${#events[@]} -eq 0 ]]; then
        echo ""
        sleep 30
        continue
    fi

    # Parse first non-ended event
    event="${events[0]}"
    start_time="${event%% *}"
    rest="${event#* }"
    end_time="${rest%% *}"
    title_part="${rest#* }"

    start_min=$(time_to_min "$start_time")
    diff=$((start_min - now_min))

    if (( ${#title_part} > MAX_TITLE_LEN )); then
        title_part="${title_part:0:$MAX_TITLE_LEN}.."
    fi

    if (( diff <= 0 )); then
        # LIVE — blink: alternate visible/invisible
        echo "%{F$COLOR_LIVE}$ICON_LIVE ${start_time} ${title_part}%{F-}"
        sleep 1
        echo "%{F$BG_COLOR}$ICON_LIVE ${start_time} ${title_part}%{F-}"
        sleep 1
    elif (( diff <= WARN_MINUTES )); then
        # WARNING — 10 min before
        echo "%{F$COLOR_WARN}$ICON_NORMAL ${start_time} ${title_part}%{F-}"
        sleep 30
    else
        # NORMAL
        echo "$ICON_NORMAL ${start_time} ${title_part}"
        sleep 30
    fi
done

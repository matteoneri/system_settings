#!/bin/bash
# Polybar memory monitor with blink at 90%

WARN_PCT=90
COLOR_WARN="#f45070"
ICON="%{T2}󰍛%{T-}"

read -r total available < <(awk '/MemTotal/{t=$2} /MemAvailable/{a=$2} END{print t, a}' /proc/meminfo)
used_kb=$(( total - available ))
used_gb=$(awk "BEGIN{printf \"%.1f\", $used_kb / 1048576}")
pct=$(( used_kb * 100 / total ))

if (( pct >= WARN_PCT )); then
    if (( $(date +%s) % 2 )); then
        echo "%{F$COLOR_WARN}$ICON ${used_gb}G%{F-}"
    else
        echo "$ICON ${used_gb}G"
    fi
else
    echo "$ICON ${used_gb}G"
fi

#!/bin/bash

PROJECTS_DIR="$HOME/Documents/Projects/ActiveProjects"

# Build project list: category/project for nested, just name for top-level
list_projects() {
    for entry in "$PROJECTS_DIR"/*/; do
        name=$(basename "$entry")
        if [[ "$name" == "OWN" || "$name" == "FNA" ]]; then
            for sub in "$entry"*/; do
                [ -d "$sub" ] && echo "$name/$(basename "$sub")"
            done
        else
            echo "$name"
        fi
    done
}

if [ -z "$1" ]; then
    project=$(list_projects | rofi -dmenu -p "Project" -config ~/.config/rofi/rofidmenu.rasi)
    [ -z "$project" ] && exit 0
else
    project="$1"
fi

path="$PROJECTS_DIR/$project"

if [ ! -d "$path" ]; then
    notify-send "Project not found" "$path"
    exit 1
fi

# Determine category (OWN/FNA) from project path
category="${project%%/*}"

# Pick browser, claude config, and kitty theme based on category
if [[ "$category" == "FNA" ]]; then
    browser_cmd="firefox"
    claude_config_dir="$HOME/.claude-fna"
    kitty_theme="$HOME/.config/kitty/themes/Hachiko.conf"
else
    browser_cmd="brave"
    claude_config_dir="$HOME/.claude-own"
    kitty_theme="$HOME/.config/kitty/themes/Dayfox.conf"
fi

# Set workspace icon based on category
if [[ "$category" == "FNA" ]]; then
    ws_icon="󰔶"
else
    ws_icon="󰉛"
fi

ws_name=$(i3-msg -t get_workspaces | jq -r '.[] | select(.focused) | .name')
# Only rename plain numeric workspaces (skip 7-10 which have static icons)
if [[ "$ws_name" =~ ^[0-9]+$ ]]; then
    i3-msg "rename workspace \"$ws_name\" to \"$ws_name:$ws_icon\""
fi

# Navigate to workspace level so a second project creates a new column
i3-msg 'focus parent; focus parent; focus parent; focus parent; split h'

# Layout target:
#   tabbed[yazi, browser]
#   ─────────────────────
#          claude
#
# Two projects side by side:
#   tabbed[yazi1, browser1] || tabbed[yazi2, browser2]
#   ────────────────────────||────────────────────────
#          claude1           ||         claude2

# 1. Open yazi (creates new column if workspace already has windows)
kitty --config "$kitty_theme" --directory "$path" -e yazi &
sleep 1

# 2. Split vertically: claude will go below yazi
i3-msg 'splitv'
kitty --config "$kitty_theme" --directory "$path" -e env CLAUDE_CONFIG_DIR="$claude_config_dir" claude &
sleep 1

# 3. Focus back up to yazi, split horizontally for the browser tab
i3-msg 'focus up; splith'
$browser_cmd --new-window "https://claude.ai" &
sleep 1

# 4. Make yazi+browser container tabbed
i3-msg 'layout tabbed'

# Obsidian if vault exists
if [ -d "$path/docs/.obsidian" ]; then
    obsidian "$path/docs" &
fi

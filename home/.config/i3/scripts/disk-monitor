#!/bin/bash
# Polybar disk monitor with blink at 90%
# Usage: disk-monitor /mount/point label

MOUNT="${1:-/}"
LABEL="${2:-/}"
WARN_PCT=90
COLOR_WARN="#f45070"
ICON="%{T2}󰋊%{T-}"

read -r size used avail pct < <(df -BG "$MOUNT" 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5); print $2,$3,$4,$5}')
[[ -z "$pct" ]] && exit 0

free="${avail}B"

if (( pct >= WARN_PCT )); then
    if (( $(date +%s) % 2 )); then
        echo "%{F$COLOR_WARN}$ICON $LABEL ${free}%{F-}"
    else
        echo "$ICON $LABEL ${free}"
    fi
else
    echo "$ICON $LABEL ${free}"
fi

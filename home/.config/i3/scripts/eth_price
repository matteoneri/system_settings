#!/bin/bash

# Fetch ETH/USD price with 24h change from CoinGecko API
data=$(curl -sf --max-time 5 \
  'https://api.coingecko.com/api/v3/simple/price?ids=ethereum&vs_currencies=usd&include_24hr_change=true')

if [ $? -ne 0 ] || [ -z "$data" ]; then
    echo $'\ued58 --'
    exit 0
fi

price=$(echo "$data" | jq -r '.ethereum.usd')
change=$(echo "$data" | jq -r '.ethereum.usd_24h_change')

# Format price (no decimals above 1000, 2 decimals below)
formatted_price=$(awk -v p="$price" 'BEGIN {
    if (p >= 1000) printf "%.0f", p
    else printf "%.2f", p
}')

# Format change percentage
formatted_change=$(awk -v c="$change" 'BEGIN { printf "%+.1f", c }')

# Color based on 24h change
if (( $(awk -v c="$change" 'BEGIN { print (c >= 0) }') )); then
    color="#5eeaa0"
else
    color="#f45070"
fi

echo "%{F$color}$(printf '\ued58') $formatted_price (${formatted_change}%)%{F-}"

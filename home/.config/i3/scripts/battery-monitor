#!/bin/bash
# Battery monitor for polybar (tail mode)
# - Red below 30%
# - Blinks below 15%
# - Alerts at 20, 15 (dunst), 10, 5 (fullscreen)

BATTERY="BAT0"
ALERT_FILE="/tmp/polybar-battery-alerts"

get_icon() {
    local cap=$1 status=$2
    if [[ "$status" == "Charging" ]]; then
        if (( cap >= 90 )); then echo "󰂊"
        elif (( cap >= 80 )); then echo "󰂉"
        elif (( cap >= 70 )); then echo "󰢞"
        elif (( cap >= 60 )); then echo "󰂈"
        elif (( cap >= 50 )); then echo "󰢝"
        elif (( cap >= 40 )); then echo "󰂇"
        elif (( cap >= 30 )); then echo "󰂆"
        elif (( cap >= 20 )); then echo "󰢜"
        elif (( cap >= 10 )); then echo "󰂅"
        else echo "󰂌"
        fi
        return
    fi
    if (( cap >= 80 )); then echo "󰁹"
    elif (( cap >= 60 )); then echo "󰂀"
    elif (( cap >= 40 )); then echo "󰁾"
    elif (( cap >= 20 )); then echo "󰁼"
    else echo "󰁺"
    fi
}

while true; do
    capacity=$(cat "/sys/class/power_supply/$BATTERY/capacity")
    status=$(cat "/sys/class/power_supply/$BATTERY/status")
    icon=$(get_icon "$capacity" "$status")

    # Reset alert tracking when charging
    [[ "$status" == "Charging" || "$status" == "Full" ]] && rm -f "$ALERT_FILE"

    ACCENT=$(cat ~/.config/theme/current 2>/dev/null || echo "#FFB347")
    if [[ "$status" == "Charging" || "$status" == "Full" ]]; then
        echo "%{F${ACCENT}}$icon $capacity%%{F-}"
        sleep 30
    elif (( capacity <= 20 )); then
        # Send alert at thresholds
        for t in 20 15 10 5; do
            if (( capacity <= t )) && ! grep -qx "$t" "$ALERT_FILE" 2>/dev/null; then
                if (( t >= 15 )); then
                    notify-send -u critical "Battery Low" "Battery at ${capacity}%!"
                else
                    ~/.config/i3/scripts/fullscreen-alert "BATTERY ${capacity}%" "CHARGE NOW!" &
                fi
                echo "$t" >> "$ALERT_FILE"
                break
            fi
        done
        if (( capacity <= 15 )); then
            # Blink below 15%
            echo "%{F#f45070}$icon $capacity%%{F-}"
            sleep 1
            echo "%{F#282c34}$icon $capacity%%{F-}"
            sleep 1
        else
            # Red but no blink at 16-20%
            echo "%{F#f45070}$icon $capacity%%{F-}"
            sleep 30
        fi
    elif (( capacity <= 30 )); then
        echo "%{F#f45070}$icon $capacity%%{F-}"
        sleep 30
    else
        echo "%{F${ACCENT}}$icon $capacity%%{F-}"
        sleep 30
    fi
done
